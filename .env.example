# ================================================
# AutoML Model Builder - Environment Configuration
# Copy this file to .env and update values
# ================================================

# Flask Configuration
FLASK_ENV=development
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production-12345

# File Upload Configuration
MAX_UPLOAD_SIZE=26214400  # 25MB in bytes
UPLOAD_DIR=uploads/datasets

# Model & Output Configuration
MODEL_DIR=outputs/models
INFERENCE_DIR=outputs/inference
REPORT_DIR=outputs/reports
LOG_DIR=logs

# Logging Configuration
LOG_LEVEL=INFO

# Training Configuration
BATCH_SIZE=32
EPOCHS=100
TEST_SPLIT=0.2
VALIDATION_SPLIT=0.2

# Model Features
ENABLE_FEATURE_ENGINEERING=True
ENABLE_HYPERPARAMETER_TUNING=False
ENABLE_CROSS_VALIDATION=True

# API Configuration
API_TIMEOUT=300
MAX_WORKERS=4

# Database Configuration (if using in future)
# DATABASE_URL=postgresql://user:password@localhost/automl_db

# Email Configuration (if using notifications)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-email-password

# Cloud Deployment (Optional)
# AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# GCP_PROJECT_ID=your-gcp-project
